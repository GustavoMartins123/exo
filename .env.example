# Exo cluster orchestration
#
# Copy this file to .env on the machine that should control the other Exo
# hosts. The dashboard shows the "Start Children" button only on the master.

EXO_CLUSTER_MASTER=true

# Optional. If set, this host is considered master when the value matches this
# machine hostname, FQDN or local IP.
# EXO_CLUSTER_MASTER_HOST=10.10.10.1

# Dedicated switch network to scan for node agents.
EXO_CLUSTER_AGENT_CIDRS=10.10.10.0/24
EXO_CLUSTER_AGENT_PORT=8765

# Optional static list instead of or in addition to CIDR discovery.
# EXO_CLUSTER_AGENT_HOSTS=10.10.10.2,10.10.10.3

# Optional shared token. Use the same value for node agent containers.
# EXO_AGENT_TOKEN=change-me
